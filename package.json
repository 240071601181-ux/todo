{
  "name": "fastodo",
  "private": true,
  "version": "0.0.0",
  "workspaces": ["frontend", "backend"],
  "scripts": {
    "dev:frontend": "npm run dev --workspace=@fastodo/frontend",
    "dev:backend": "npm run dev --workspace=@fastodo/backend",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "build:frontend": "npm run build --workspace=@fastodo/frontend",
    "build:backend": "npm run build --workspace=@fastodo/backend",
    "build": "npm run build:backend && npm run build:frontend",
    "lint": "npm run lint --workspace=@fastodo/frontend",
    "db:generate": "npm run db:generate --workspace=@fastodo/backend",
    "db:push": "npm run db:push --workspace=@fastodo/backend",
    "db:migrate": "npm run db:migrate --workspace=@fastodo/backend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
